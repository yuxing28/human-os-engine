# NVIDIA NIM API Key
NVIDIA_API_KEYS=your-api-key-1,your-api-key-2

# NVIDIA NIM Base URL (optional)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA Model (optional)
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# SCNet API Keys（用于话术生成，兼容 OpenAI 接口，支持多个 Key 轮询）
SCNET_API_KEYS=your-scnet-api-key-1,your-scnet-api-key-2
SCNET_BASE_URL=https://api.scnet.cn/api/llm/v1
SCNET_MODEL=DeepSeek-V3.2

# DeepSeek 官方 API（直接调用，更稳定，推荐优先使用）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Debug mode
DEBUG=false
