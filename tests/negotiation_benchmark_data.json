{
  "version": "1.0.0",
  "description": "高风险商务谈判场景标准题库 (Golden Set) - 用于回归测试",
  "scenarios": [
    { "id": 1, "category": "锚定重置", "input": "我们的预算上限就是 100 万，多一分钱都要走董事会特批，这通常要耗时半年。", "expected_goal": "negotiation.anchor_reset" },
    { "id": 2, "category": "锚定重置", "input": "这个价格完全超出了行业均值，我们需要重新核算模型。", "expected_goal": "negotiation.anchor_reset" },
    { "id": 3, "category": "锚定重置", "input": "对方报出了一个只有市场价 40% 的起手价", "expected_goal": "negotiation.anchor_reset" },
    { "id": 4, "category": "锚定重置", "input": "我们的财务部门说这个成本拆解不合理，需要第三方数据支持。", "expected_goal": "negotiation.anchor_reset" },
    { "id": 5, "category": "锚定重置", "input": "你们的逻辑有问题，我们需要重新评估这个变量。", "expected_goal": "negotiation.anchor_reset" },
    { "id": 6, "category": "BATNA 增强", "input": "我们是市场唯一买家。接受这个价，或者看着你们的库存过期。", "expected_goal": "negotiation.batna_strengthening" },
    { "id": 7, "category": "BATNA 增强", "input": "我们有备选供应商，正在第三方询价。", "expected_goal": "negotiation.batna_strengthening" },
    { "id": 8, "category": "BATNA 增强", "input": "如果谈不拢，我们就启动自研计划。", "expected_goal": "negotiation.batna_strengthening" },
    { "id": 9, "category": "BATNA 增强", "input": "我们有延期选项和冗余方案，不急这一时。", "expected_goal": "negotiation.batna_strengthening" },
    { "id": 10, "category": "BATNA 增强", "input": "寻找他途比继续谈下去更有价值。", "expected_goal": "negotiation.batna_strengthening" },
    { "id": 11, "category": "利益探寻", "input": "为什么你们坚持这个条款？您的担忧是什么？", "expected_goal": "negotiation.interest_probing" },
    { "id": 12, "category": "利益探寻", "input": "如果价格不变，底层逻辑是什么？", "expected_goal": "negotiation.interest_probing" },
    { "id": 13, "category": "利益探寻", "input": "除了价格，核心优先级是什么？", "expected_goal": "negotiation.interest_probing" },
    { "id": 14, "category": "利益探寻", "input": "目标对齐后，风险点在哪里？", "expected_goal": "negotiation.interest_probing" },
    { "id": 15, "category": "利益探寻", "input": "我想了解你们真正的痛点。", "expected_goal": "negotiation.interest_probing" },
    { "id": 16, "category": "价值阐述", "input": "我们要看业务成果和 ROI，而不是功能描述。", "expected_goal": "negotiation.value_articulation" },
    { "id": 17, "category": "价值阐述", "input": "风险降低和战略对齐才是关键。", "expected_goal": "negotiation.value_articulation" },
    { "id": 18, "category": "价值阐述", "input": "收入加速和生命周期价值怎么算？", "expected_goal": "negotiation.value_articulation" },
    { "id": 19, "category": "价值阐述", "input": "商业影响和成功标准是什么？", "expected_goal": "negotiation.value_articulation" },
    { "id": 20, "category": "价值阐述", "input": "我们用了旧系统 15 年，换新的培训成本太高。", "expected_goal": "negotiation.value_articulation" },
    { "id": 21, "category": "共识对齐", "input": "IT 部门和财务部门意见不一致，我们需要跨部门共识。", "expected_goal": "negotiation.consensus_alignment" },
    { "id": 22, "category": "共识对齐", "input": "决策节点太多，委员会无法达成一致。", "expected_goal": "negotiation.consensus_alignment" },
    { "id": 23, "category": "共识对齐", "input": "内部障碍太多，利益协调困难。", "expected_goal": "negotiation.consensus_alignment" },
    { "id": 24, "category": "共识对齐", "input": "销售 VP 承诺了功能，但技术负责人现场拆台。", "expected_goal": "negotiation.consensus_alignment" },
    { "id": 25, "category": "共识对齐", "input": "由于地缘风险，财务部要求延迟付款，IT 部要求本地化部署。", "expected_goal": "negotiation.consensus_alignment" },
    { "id": 26, "category": "情感重塑", "input": "对方代表拍桌子指责你们完全没有诚意。", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 27, "category": "情感重塑", "input": "我感受到你的愤怒，这对您很重要。", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 28, "category": "情感重塑", "input": "让我们聚焦背后利益，重塑新视角。", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 29, "category": "情感重塑", "input": "资方语气强硬，导致劳方宁愿罢工也不接受调解。", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 30, "category": "情感重塑", "input": "转化为对实质性利益的关注，而非对抗。", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 31, "category": "边界情况", "input": "你好", "expected_goal": null },
    { "id": 32, "category": "边界情况", "input": "嗯", "expected_goal": null },
    { "id": 33, "category": "边界情况", "input": "好的", "expected_goal": null },
    { "id": 34, "category": "边界情况", "input": "？？？", "expected_goal": null },
    { "id": 35, "category": "边界情况", "input": "asdfghjkl", "expected_goal": null },
    { "id": 36, "category": "边界情况", "input": "1234567890", "expected_goal": null },
    { "id": 37, "category": "边界情况", "input": "我想聊聊", "expected_goal": "negotiation.interest_probing" },
    { "id": 38, "category": "边界情况", "input": "最近压力大", "expected_goal": "negotiation.emotional_reframing" },
    { "id": 39, "category": "边界情况", "input": "太贵了", "expected_goal": "negotiation.anchor_reset" },
    { "id": 40, "category": "边界情况", "input": "不想谈了", "expected_goal": "negotiation.strategic_impasse" }
  ]
}
